{
  "author": "Adrian de la Rosa <adrian@delarosab.me>",
  "bugs": {
    "url": "https://github.com/mormubis/uci/issues"
  },
  "dependencies": {
    "emittery": "^1.1.0",
    "zod": "^3.24.2"
  },
  "description": "UCI is a Universal Chess Interface that is part of the ECHECS project, providing a standardized way for chess engines to communicate with graphical user interfaces (GUIs).",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^22.13.14",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.3.1",
    "eslint-plugin-import-x": "^4.9.4",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^4.0.1"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "/dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "homepage": "https://github.com/mormubis/uci#readme",
  "keywords": [
    "chess",
    "fide",
    "interface",
    "uci",
    "universal chess interface",
    "chess engine"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@echecs/uci",
  "repository": {
    "type": "git",
    "url": "https://github.com/mormubis/uci.git"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "format": "pnpm run format:ci --write",
    "format:ci": "prettier -l \"**/*.+(css|js|json|jsx|md|mjs|mts|ts|tsx|yml|yaml)\"",
    "lint": "pnpm run lint:style && pnpm run lint:types",
    "lint:ci": "pnpm run lint:style --max-warnings 0 && pnpm run lint:types",
    "lint:style": "eslint \"src/**/*.{ts,tsx}\" \"*.mjs\" --fix",
    "lint:types": "tsc --noEmit --project tsconfig.json",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "pnpm run test --coverage",
    "test:watch": "pnpm run test --watch"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "1.0.0"
}
